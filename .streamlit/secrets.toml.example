# Streamlit Secrets Configuration (Example)
# DO NOT commit this file with real secrets!
# 
# For local development:
# 1. Copy this file to: .streamlit/secrets.toml
# 2. Fill in your real API keys
# 3. Make sure .streamlit/secrets.toml is in .gitignore
#
# For Streamlit Cloud deployment:
# 1. Go to your app settings on Streamlit Cloud
# 2. Navigate to "Secrets" section
# 3. Paste the content below with your real keys

[default]
OPENAI_API_KEY = "sk-proj-..."
LOGFIRE_TOKEN = "pylf_v1_..."

# Alternative format (also supported):
# OPENAI_API_KEY = "sk-proj-..."
# LOGFIRE_TOKEN = "pylf_v1_..."
